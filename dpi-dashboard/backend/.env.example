# Port the Express server listens on
PORT=5000

# Comma-separated list of origins allowed to call this API
# For local dev: http://localhost:5173
# For production: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# Absolute or relative path to the compiled DPI engine binary.
# On Windows this will end in .exe, on Render (Linux) it will not.
DPI_ENGINE_PATH=./cpp/dpi_engine

# Max upload size in bytes (default 100MB)
MAX_UPLOAD_BYTES=104857600

# Milliseconds before a stuck engine process is killed
ENGINE_TIMEOUT_MS=120000
